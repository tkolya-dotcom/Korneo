{
  "name": "korneo-mobile",
  "version": "2.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~51.0.28",
    "expo-router": "~3.5.23",
    "expo-linking": "~6.3.5",
    "expo-status-bar": "~2.0.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "@react-native/gradle-plugin": "^0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "@supabase/supabase-js": "^2.45.4",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "nativewind": "^4.0.1",
    "tailwindcss": "3.3.2",
    "expo-notifications": "~0.28.12"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "typescript": "~5.3.3",
    "@types/react": "~18.2.45"
  },
  "overrides": {
    "react": "18.2.0"
  },
  "expo": {
    "name": "Korneo Mobile",
    "slug": "korneo-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications"
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  },
  "packageManager": "npm@10.8.2"
}

